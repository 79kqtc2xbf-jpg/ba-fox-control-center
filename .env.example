# BA Fox / Executive Fox environment variables
# Copy this file to .env for local development.
# Never commit real tokens, secrets, or service account JSON files.

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_OWNER_CHAT_ID=your_telegram_chat_id_here

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google credentials option A: local file
# Put service-account.json in the project root locally and keep it uncommitted.
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json

# Google credentials option B: hosting env var
# Paste the full service account JSON as one-line JSON in hosting secrets.
# Recommended for Railway / Render.
GOOGLE_SERVICE_ACCOUNT_JSON=

# App settings
TIMEZONE=Asia/Bangkok
REMINDER_MODE=combo

# Reminder times, local app timezone
MORNING_PROMPT_TIME=10:00
MIDDAY_CHECK_TIME=12:30
PUSH_CHECK_TIME=15:30
EVENING_REPORT_TIME=19:30
